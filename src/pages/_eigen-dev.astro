---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ComplexPlane from "@/components/eigen/plots/ComplexPlane";
import Trajectory from "@/components/eigen/plots/Trajectory";
import { integrate2x2 } from "@/components/eigen/math/integrate";

const xs = integrate2x2([[-1, 0], [0, -2]], [1, 1], { dt: 0.05, steps: 200 });
const x1 = xs.map((p) => p[0]);
const x2 = xs.map((p) => p[1]);
---
<BaseLayout title="Eigen dev">
  <h1 class="text-2xl font-bold mb-4">Eigen primitive harness (delete in Task 12)</h1>

  <h2 class="text-lg mt-6 mb-2">ComplexPlane</h2>
  <ComplexPlane
    client:load
    points={[
      { re: -10, im: 0, color: "#7c3aed", draggable: true, id: "l1" },
      { re: -2, im: 0, color: "#7c3aed", draggable: true, id: "l2" },
    ]}
  />

  <h2 class="text-lg mt-6 mb-2">Trajectory</h2>
  <Trajectory
    client:load
    dt={0.05}
    series={[
      { values: x1, color: "#06b6d4", label: "x1" },
      { values: x2, color: "#a78bfa", label: "x2" },
    ]}
  />
</BaseLayout>
